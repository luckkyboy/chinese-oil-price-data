{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/luckkyboy/chinese-oil-price-data/schema/calendar-latest.schema.json",
  "title": "Latest Chinese oil price adjustment calendar pointer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "year",
    "path",
    "updated_at"
  ],
  "properties": {
    "year": {
      "type": "integer",
      "minimum": 2000,
      "maximum": 2100
    },
    "path": {
      "type": "string",
      "pattern": "^/data/calendar/[0-9]{4}\\.json$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
