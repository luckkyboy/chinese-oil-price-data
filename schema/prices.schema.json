{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/luckkyboy/chinese-oil-price-data/schema/prices.schema.json",
  "title": "Chinese oil price snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "adjustment_date",
    "effective_from",
    "timezone",
    "unit",
    "currency",
    "products",
    "provinces",
    "updated_at"
  ],
  "properties": {
    "adjustment_date": {
      "type": "string",
      "format": "date"
    },
    "effective_from": {
      "type": "string",
      "format": "date-time"
    },
    "timezone": {
      "const": "Asia/Shanghai"
    },
    "unit": {
      "const": "CNY/L"
    },
    "currency": {
      "const": "CNY"
    },
    "products": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/productCode"
      }
    },
    "provinces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/province"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "productCode": {
      "type": "string",
      "enum": [
        "89",
        "92",
        "95",
        "0"
      ]
    },
    "priceItems": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "89": {
          "type": "number",
          "minimum": 0
        },
        "92": {
          "type": "number",
          "minimum": 0
        },
        "95": {
          "type": "number",
          "minimum": 0
        },
        "0": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "province": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "province_code",
        "province_name",
        "zones",
        "sources"
      ],
      "properties": {
        "province_code": {
          "type": "string",
          "pattern": "^[0-9]{6}$"
        },
        "province_name": {
          "type": "string",
          "minLength": 1
        },
        "zones": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/zone"
          }
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source"
          }
        }
      }
    },
    "zone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zone_code",
        "zone_name",
        "items"
      ],
      "properties": {
        "zone_code": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "zone_name": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "$ref": "#/$defs/priceItems"
        },
        "missing_products": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/productCode"
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "url"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
